# WorkMy FastAPI Backend — Variáveis de Ambiente
# Copie: cp .env.example .env
# NÃO versionar o .env real!

# ── Banco de dados ────────────────────────────────────────────────────────────
# SQLite (desenvolvimento local sem Docker):
DATABASE_URL=sqlite+aiosqlite:///./db.sqlite3
# PostgreSQL (Docker / staging / produção):
# DATABASE_URL=postgresql+asyncpg://workmy_user:workmy_password@localhost:5432/workmy_db

# ── JWT ───────────────────────────────────────────────────────────────────────
# OBRIGATÓRIO em produção. Gere uma chave segura com:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
# Se não configurado, uma chave aleatória é gerada por processo (só dev)
# JWT_SECRET_KEY=sua_chave_super_secreta_aqui

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
# Docker:
# RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# ── CORS ─────────────────────────────────────────────────────────────────────
# Origens permitidas separadas por vírgula.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
# Produção:
# CORS_ORIGINS=https://app.workmy.com

# ── Logging ──────────────────────────────────────────────────────────────────
# 'text' para desenvolvimento (legível por humanos)
# 'json' para produção (ingest em Datadog, Loki, CloudWatch, etc.)
LOG_FORMAT=text
# LOG_FORMAT=json

# ── Testes ───────────────────────────────────────────────────────────────────
# TESTING=1  (usado pelo jwt_service.py para usar chave JWT fixa em testes)
