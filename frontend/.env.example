# ─────────────────────────────────────────────────────────────────────────────
# Cópia local APENAS: cp .env.example .env
# NÃO commitar .env — deploy automático no Vercel lê o painel Environment.
# ─────────────────────────────────────────────────────────────────────────────

# ── Produção (painel Vercel — não colocar URL real aqui no repositório) ───────
# VITE_API_BASE_URL=https://SEU-BACKEND.onrender.com/api
# VITE_DEMO_MODE=false

# ── Desenvolvimento local com backend Django ─────────────────────────────────
# VITE_API_BASE_URL=http://127.0.0.1:8000/api
# VITE_DEMO_MODE=false

# ── Modo demonstração (sem backend) ───────────────────────────────────────────
VITE_DEMO_MODE=true
