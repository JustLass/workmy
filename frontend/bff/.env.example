# WorkMy BFF Proxy Gateway — Variáveis de Ambiente
# Copie este arquivo: cp .env.example .env
# Não versionar o .env real!

# ── FastAPI Core URL ─────────────────────────────────────────────────────────
# URL base do backend FastAPI que o BFF faz proxy.
# Dev local:
FASTAPI_URL=http://127.0.0.1:8000
# Produção (ex: Render/Railway):
# FASTAPI_URL=https://api.workmy.com

# ── Porta do BFF ─────────────────────────────────────────────────────────────
PORT=3000

# ── CORS — origem permitida do frontend ──────────────────────────────────────
# Múltiplas origens separadas por vírgula.
# Dev local:
CORS_ORIGIN=http://localhost:5173
# Produção:
# CORS_ORIGIN=https://app.workmy.com

# ── Ambiente ─────────────────────────────────────────────────────────────────
# Em produção, define cookies com secure=true e sameSite=strict.
# NODE_ENV=production
NODE_ENV=development
