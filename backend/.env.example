# ─────────────────────────────────────────────────────────────────────────────
# ⚠️ IMPORTANTE: NÃO COMMITAR .env — arquivo de configuração local
# ─────────────────────────────────────────────────────────────────────────────
# Cópia local: cp .env.example .env
# Produção (Render): configure TODAS as variáveis no painel do serviço Web
# O Render define RENDER=true; o Django ignora .env em produção
# ─────────────────────────────────────────────────────────────────────────────

# ============ SEGURANÇA ============
# IMPORTANTE: Gerar nova SECRET_KEY para cada ambiente
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DEBUG=True
SECRET_KEY=troque-por-uma-chave-segura-local-minimo-50-caracteres

# ============ DATABASE ============
# Desenvolvimento: SQLite (padrão)
DATABASE_URL=sqlite:///db.sqlite3

# Produção: PostgreSQL (Render, Supabase, AWS)
# DATABASE_URL=postgresql://usuario:senha@host:5432/database

# ============ HOSTS PERMITIDOS ============
ALLOWED_HOSTS=127.0.0.1,localhost

# ============ FRONTEND API ============
VITE_API_BASE_URL=http://127.0.0.1:8000/api

# ============ CORS ============
# Frontend local (desenvolvimento)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Frontend produção (adicionar domínios reais)
# CORS_ALLOWED_ORIGINS=https://seu-frontend.vercel.app

# ============ CSRF ============
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ============ EMAIL (Opcional - para password reset) ============
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=seu_email@gmail.com
# EMAIL_HOST_PASSWORD=sua_senha_app_google

