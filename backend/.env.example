# ─────────────────────────────────────────────────────────────────────────────
# Cópia local APENAS: cp .env.example .env
# NÃO commitar .env — o git push não deve levar segredos nem configs de produção.
# Produção (Render): configure TODAS as variáveis no painel do serviço Web.
# O Render define RENDER=true; o Django ignora este arquivo em produção.
# ─────────────────────────────────────────────────────────────────────────────

DEBUG=True
SECRET_KEY=troque-por-uma-chave-segura-local

# PostgreSQL / Supabase (desenvolvimento)
DATABASE_URL=postgresql://usuario:senha@host:5432/postgres

ALLOWED_HOSTS=127.0.0.1,localhost

# CORS (frontend local Vite)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
